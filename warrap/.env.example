# Warrap — Environment Variables
# Copy to .env and fill in your values. NEVER commit .env to git.

# Django
SECRET_KEY=your-super-secret-django-key-change-this-now
DJANGO_SETTINGS_MODULE=warrap.settings.dev
DEBUG=True
ALLOWED_HOSTS=localhost 127.0.0.1

# Database (PostGIS)
DATABASE_URL=postgis://postgres:postgres@localhost:5432/warrap_db

# Redis
REDIS_URL=redis://127.0.0.1:6379/1

# App config
MAP_CACHE_TTL=30
HUSTLE_PROXIMITY_RADIUS_M=5000
SITE_URL=http://localhost:8000

# Google OAuth (Social Login)
# Setup: https://console.cloud.google.com -> APIs & Services -> Credentials
# Redirect URI: http://localhost:8000/accounts/google/login/callback/
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Email (prod only)
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_HOST_USER=your@gmail.com
# EMAIL_HOST_PASSWORD=your-app-password
# DEFAULT_FROM_EMAIL=noreply@warrap.cm
