# Copy to .env.docker before running docker compose.

SECRET_KEY=change-this-local-docker-secret
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0

DB_NAME=warrap_db
DB_USER=warrap
DB_PASSWORD=warrap
