DB_PORT=5432
DATABASE_URL=postgis://warrap:warrap@db:5432/warrap_db

REDIS_URL=redis://redis:6379/1
MAP_CACHE_TTL=30
HUSTLE_PROXIMITY_RADIUS_M=5000
SITE_URL=http://localhost:8000

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_ADMIN_EMAIL=admin@warrap.cm
